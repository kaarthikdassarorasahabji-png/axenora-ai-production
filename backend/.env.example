# Server Configuration
NODE_ENV=development
PORT=5000

# Frontend URL
CLIENT_URL=https://axenoraai.in

# Supabase Configuration (get from your Supabase project settings)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key

# Resend Email Configuration (https://resend.com)
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=Axenora AI <noreply@axenoraai.in>
ADMIN_EMAIL=kaarthikdassarorasahabji@gmail.com
LEADS_EMAIL=kaarthikdassarorasahabji@gmail.com

# LLM provider (configure one provider; OpenAI is preferred)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini
# Optional OpenRouter fallback
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=nvidia/nemotron-nano-9b-v2:free

# Razorpay Configuration (https://razorpay.com)
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Optional: Other Services
# GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X
# SENTRY_DSN=https://your-sentry-dsn

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
